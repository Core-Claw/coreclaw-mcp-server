# Copy to .env for local deployment scripts. Do not commit .env.

# SSH deployment target
SSH_HOST=1.2.3.4
SSH_PORT=22
SSH_USER=ubuntu
# Optional private key. Leave empty to use ssh-agent/default key.
# SSH_KEY=~/.ssh/id_rsa

# Remote deployment
DEPLOY_DIR=/opt/coreclaw-mcp-server
SERVICE_NAME=coreclaw-mcp-server

# Runtime
CORECLAW_BASE_URL=https://openapi.coreclaw.com
MCP_PORT=3000

# Local stdio development only. Remote HTTP mode should receive each user's
# CoreClaw token from request headers instead of using a shared server token.
CORECLAW_API_KEY=

# Privilege and systemd behavior
USE_SUDO=yes
SERVICE_USER=root
OPEN_UFW=no
USE_SYSTEMD=yes

# Nginx reverse proxy
NGINX_SERVER_NAME=mcp.coreclaw.com
NGINX_LISTEN_PORT=80
